# Copy to group_vars/secrets.yml (file is git-ignored) or pass sensitive values with: ansible-playbook ... -e "do_token=..."
# Never commit real tokens.

# --- Example: DigitalOcean ---
# do_token: "dop_v1_..."
# (region, server_name, and provider are often set in all.yml; override here if you prefer)

# --- Example: AWS (EC2 / Lightsail) ---
# aws_access_key: "AKIA..."
# aws_secret_key: "..."
# region: "us-east-1"

# --- Example: Google Cloud (GCE) ---
# gce_credentials_file: "/path/to/svcaccount.json"
# region: "us-west1"

# --- Example: Azure ---
# azure_tenant: "..."
# azure_client_id: "..."
# azure_secret: "..."
# azure_subscription_id: "..."
# region: "westus2"

# --- Hetzner ---
# hcloud_token: "..."

# --- Linode ---
# linode_token: "..."

# --- Scaleway ---
# scaleway_token: "..."

# --- Vultr (ini path) ---
# vultr_config: "/path/to/.vultr.ini"

# --- CloudStack / Exoscale ---
# cs_config: "/path/to/.cloudstack.ini"
# cs_region: "..."
# cs_zones: "..."

# --- Install on existing host (local) ---
# server: "203.0.113.10"
# endpoint: "203.0.113.10"
# ssh_user: "ubuntu"
# ca_password: "long-random"
# p12_export_password: "..."   # optional

# --- Optional Telegram (after successful Algo; not in upstream Algo) ---
# telegram_notify: true
# telegram_bot_token: "123:ABC"
# telegram_chat_id: "12345"
